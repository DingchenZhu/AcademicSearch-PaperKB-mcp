# Copy this file to .env and fill in your values.

# --- Embedding provider ---
# Set to "openai", "nvidia_nim", or "local_ollama"
EMBEDDING_PROVIDER=openai

# OpenAI-compatible embedding endpoint
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# NVIDIA NIM (alternative)
# OPENAI_API_KEY=<nvapi-key>
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# --- Knowledge base storage ---
# Absolute path to the SQLite DB file
KB_DB_PATH=./data/kb.sqlite

# PDF download cache directory
PDF_CACHE_DIR=./data/pdf_cache

# --- Retriever backend ---
# "linear" (default, no extra deps) or "faiss" (requires faiss-cpu)
KB_RETRIEVER_BACKEND=linear

# --- MCP server ports ---
ACADEMIC_SEARCH_PORT=9001
PAPER_KB_PORT=9002

# --- Optional REST API ---
REST_API_PORT=8000
